// -- CONTEXT RULES -------------------------------------------------
import com.ftn.sbnz.model.events.ContextReading


// --- Context: PostMaintenance + Temperature anomaly ---
rule "Post-maintenance temperature rise"
no-loop true
when
    $m : Machine($id : id)
    not AlertLock(machineId == $id, alertType == "PM_HEAT")

    ContextReading(machineId == $id, context == "POST_MAINTENANCE") over window:time(1h)
    accumulate(
        $t : TemperatureReading(machineId == $id, value > 80) over window:time(30m),
        $count : count($t)
    )
    eval($count >= 3)
then
    insert(new AlertLock($id, "PM_HEAT"));
    modify($m) {
        setStatus()
        addRecommendation("CEP: Sumnjiv rast temperature odmah nakon servisa!")
    }
    backwardService.triggerSimpleAlert($m, "CEP: Post-Maint Warning", "Temperatura raste neuobičajeno brzo nakon servisiranja.");
end


// --- Context: HighLoad + High vibration ---
rule "High load vibration anomaly"
no-loop true
when
    $m : Machine($id : id, status in (MachineStatus.NORMAL, MachineStatus.SUSPICIOUS))
    not AlertLock(machineId == $id, alertType == "HIGH_LOAD_VIB")

    ContextReading(machineId == $id, context == "HIGH_LOAD") over window:time(10m)
    accumulate(
        $v : VibrationReading(machineId == $id, value > 8.0) over window:time(5m),
        $count : count($v)
    )
    eval($count >= 3)
then
    insert(new AlertLock($id, "HIGH_LOAD_VIB"));
    modify($m) {
        setStatus(MachineStatus.SUSPICIOUS),
        addRecommendation("CEP: Visoke vibracije pri velikom opterećenju.")
    }
    backwardService.triggerSimpleAlert($m, "CEP: Load Warning", "Povišene vibracije detektovane tokom režima visokog opterećenja.");
end


// --- Context: Idle + Elevated temperature ---
rule "Idle machine with high temperature"
no-loop true
when
    $m : Machine($id : id, status != MachineStatus.CRITICAL)
    not AlertLock(machineId == $id, alertType == "IDLE_HEAT")

    ContextReading(machineId == $id, context == "IDLE") over window:time(30m)
    accumulate(
        $t : TemperatureReading(machineId == $id, value > 60) over window:time(10m),
        $count : count($t)
    )
    eval($count >= 2)
then
    insert(new AlertLock($id, "IDLE_HEAT"));
    modify($m) {
        setStatus(MachineStatus.RISKY),
        addRecommendation("CEP: Visoka temperatura u stanju mirovanja.")
    }
    backwardService.triggerSimpleAlert($m, "CEP: Idle Warning", "Mašina se pregreva dok je u praznom hodu.");
end

