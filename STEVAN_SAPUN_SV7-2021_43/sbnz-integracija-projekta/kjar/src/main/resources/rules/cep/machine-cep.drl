// -- RULES FROM SPECIFICATION ----------------------------------------------
import com.ftn.sbnz.model.events.CurrentReading

// --- Rapid vibration increase (relative change) ---
rule "Vibration jump 20% in 30 seconds"
no-loop true
when
    $m : Machine($id : id, status == MachineStatus.NORMAL)
    not AlertLock(machineId == $id, alertType == "VIBRATION_JUMP")

    // CEP Sequence logic
    $v2 : VibrationReading(machineId == $id)
    not VibrationReading(machineId == $id, this after $v2)
    $v1 : VibrationReading(machineId == $id, this before $v2)
    not VibrationReading(machineId == $id, this before $v2, this after $v1)

    eval(($v2.getValue() - $v1.getValue()) / $v1.getValue() > 0.2)
then
    insert(new AlertLock($id, "VIBRATION_JUMP"));
    modify($m) {
        setStatus(MachineStatus.SUSPICIOUS),
        addRecommendation("Nagla promena vibracija (skok > 20%) – proveri rotor i pričvršćenja.")
    }
    System.out.println("CEP Rule fired: Rapid vibration increase for " + $m.getName());
    backwardService.triggerSimpleAlert($m, "CEP: Vibration Jump", "Nagla promena vibracija (>20%) detektovana u strimu – proveri rotor i pričvršćenja.");
end

// --- Prolonged high vibration (5 min spike) ---
rule "High vibration sustained 5 min"
no-loop true
when
    $m : Machine($id : id, status in (MachineStatus.NORMAL, MachineStatus.SUSPICIOUS))
    accumulate(
        $v : VibrationReading(machineId == $id, value > 10) over window:time(5m),
        $count : count($v)
    )
    eval($count >= 3)
then
    insert(new AlertLock($id, "SUSTAINED_VIB"));
    modify($m) {
        setStatus(MachineStatus.RISKY),
        addRecommendation("CEP: Učestale visoke vibracije (>10) u prozoru od 5 minuta - proveri rotor i pričvršćenja.")
    }
    backwardService.triggerSimpleAlert($m, "CEP: Sustained Vibration", "Učestale vibracije u poslednjih 5 minuta ukazuju na problem sa debalansom.");
end

// --- Prolonged heating (30 min > 80°C) ---
rule "Temperature > 80°C for 2 minutes"
no-loop true
when
    $m : Machine($id : id, status == MachineStatus.NORMAL)
    not AlertLock(machineId == $id, alertType == "SUSTAINED_HEAT")
    accumulate(
        $t : TemperatureReading(machineId == $id, value > 80) over window:time(2m),
        $count : count($t)
    )
    eval($count >= 3)
then
    insert(new AlertLock($id, "SUSTAINED_HEAT"));
    modify($m) {
        setStatus(MachineStatus.RISKY),
        addRecommendation("CEP: Temperatura povišena (>80) duže od 2 minuta – moguće habanje ležaja.")
    }

    System.out.println("CEP Rule fired: Prolonged heating for " + $m.getName());

    // 5. TRIGGER DIRECT ALERT (Path B)
    // We use triggerSimpleAlert because the history (10 readings in a window)
    // is the proof itself. We don't need a backward chaining logic tree here.
    backwardService.triggerSimpleAlert($m, "CEP: Sustained Heating", "Detektovano je povišeno zagrevanje koje traje duže od 2 minuta.");
end

// --- Prolonged high current (15 min > 100% rated) ---
rule "Current > 100% for 15 minutes"
no-loop true
when
    $m : Machine($id : id, status != MachineStatus.CRITICAL)
    not AlertLock(machineId == $id, alertType == "SUSTAINED_CURRENT")

    accumulate(
        $c : CurrentReading(machineId == $id, value > 100) over window:time(15m),
        $count : count($c)
    )
    eval($count >= 3)
then
    insert(new AlertLock($id, "SUSTAINED_CURRENT"));
    modify($m) {
        setStatus(MachineStatus.RISKY),
        addRecommendation("CEP: Dugotrajno preopterećenje strujom (>100%) detektovano - smanji struju.")
    }
    backwardService.triggerSimpleAlert($m, "CEP: Sustained Overload", "Preopterećenje traje duže od 15 minuta; smanji struju ili opterećenje.");
end

// --- Combined vibration + temperature anomaly in 10 minutes ---
rule "Vibration + Temperature anomaly 10 minutes"
no-loop true
when
    $m : Machine($id : id, status not in (MachineStatus.CRITICAL, MachineStatus.RISKY))
    not AlertLock(machineId == $id, alertType == "COMBINED_ANOMALY")

    $vCount : Number(intValue >= 1) from accumulate(
        VibrationReading(machineId == $id, value > 7.1) over window:time(10m), count()
    )
    $tCount : Number(intValue >= 1) from accumulate(
        TemperatureReading(machineId == $id, value > 85) over window:time(10m), count()
    )
then
    insert(new AlertLock($id, "COMBINED_ANOMALY"));
    modify($m) {
        setStatus(MachineStatus.RISKY),
        addRecommendation("CEP: Kombinovana anomalija temperature i vibracija (10m prozor) – mogući problem sa ležajevima.")
    }
    backwardService.triggerSimpleAlert($m, "CEP: Multi-Sensor Anomaly", "Kombinacija povišene temperature i vibracija – mogući problem sa ležajevima.");
end

